<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    <menuitem id="isy_menu_isy_card" name="ISY Card" parent="account_accountant.menu_accounting" sequence="5"/>

        <!-- Card Recharge History Tree -->
        <record model="ir.ui.view" id="isy_clinic_request_calendar">
            <field name="name">ISY Card Recharge History Tree</field>
            <field name="model">isy.card.recharge.history</field>
            <field name="arch" type="xml">
                <tree default_order='name desc'>
                    <field name="partner_id"/>
                    <field name="student_number"/>
                    <field name="barcode"/>
                    <field name="amount"/>
                    <field name="date"/>
                </tree>
            </field>
        </record>


        <!-- Card Recharge History Action -->
        <record model="ir.actions.act_window" id="menu_isy_card_recharge_history_action">
            <field name="name">Card Recharge History</field>
            <field name="res_model">isy.card.recharge.history</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
            <field name="domain">[]</field>
        </record>

        <!-- Card Recharge History Menu --> 
        <menuitem
            name="Card Recharge History"
            id="menu_isy_card_recharge_history"
            parent="isy_menu_isy_card"
            action="menu_isy_card_recharge_history_action"
            sequence="10"/>
    </data>
</odoo>
