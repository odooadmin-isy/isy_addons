<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_payment_method_view_form_inherit_isy_card" model="ir.ui.view">
        <field name="name">pos.payment.method.form.inherit.isy_card</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='split_transactions']" position="before">
                <field name="use_card" />
                <field name="send_email" />
            </xpath>
        </field>
    </record>

    <record id="view_pos_order_line_pivot_custom" model="ir.ui.view">
        <field name="name">pos.order.line.pivot.custom</field>
        <field name="model">pos.order.line</field>
        <field name="arch" type="xml">
            <pivot string="Order Lines">
                <field name="qty" type="measure"/>
                <field name="price_subtotal" type="measure"/>
                <field name="product_id" type="row"/>
                <field name="create_date" type="col" interval="day"/>
            </pivot>
        </field>
    </record>

    <record id="action_pos_order_line_custom" model="ir.actions.server">
        <field name="name">Order lines</field>
        <field name="model_id" ref="point_of_sale.model_pos_order_line"/>
        <field name="state">code</field>
        <field name="code">
            action = env['pos.order.line.action.helper'].get_my_pos_order_lines()
        </field>
    </record>

    <menuitem id="menu_pos_order_line_day"
        name="Order Lines"
        parent="point_of_sale.menu_point_of_sale"
        action="isy_pos_addon.action_pos_order_line_custom"
        groups="point_of_sale.group_pos_user"/>

</odoo>
