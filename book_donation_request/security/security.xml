<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_book_donation" model="ir.module.category">
        <field name="name">Book Donations</field>
        <field name="description">Book donation list requests and approvals</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_book_donation_librarian" model="res.groups">
        <field name="name">Librarian</field>
        <field name="category_id" ref="module_category_book_donation"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_book_donation_first_approver" model="res.groups">
        <field name="name">First Approver</field>
        <field name="category_id" ref="module_category_book_donation"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_book_donation_second_approver" model="res.groups">
        <field name="name">Second Approver</field>
        <field name="category_id" ref="module_category_book_donation"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_book_donation_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_book_donation"/>
        <field name="implied_ids" eval="[
            (4, ref('group_book_donation_librarian')),
            (4, ref('group_book_donation_first_approver')),
            (4, ref('group_book_donation_second_approver')),
        ]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <record id="book_donation_request_rule_librarian_own" model="ir.rule">
        <field name="name">Librarian: own donation requests</field>
        <field name="model_id" ref="model_book_donation_request"/>
        <field name="domain_force">[('librarian_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_book_donation_librarian'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="book_donation_request_rule_approvers_all" model="ir.rule">
        <field name="name">Approvers and managers: all donation requests</field>
        <field name="model_id" ref="model_book_donation_request"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[
            (4, ref('group_book_donation_first_approver')),
            (4, ref('group_book_donation_second_approver')),
            (4, ref('group_book_donation_manager')),
        ]"/>
    </record>
</odoo>
